# ===== 应用配置 =====
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=your-secret-key-change-in-production
APP_ALLOWED_HOSTS=["localhost","127.0.0.1"]

# ===== 数据库配置 =====
# PostgreSQL（业务数据）— 映射到宿主机 5433
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5433/quant_db

# TimescaleDB（行情时序数据）— 映射到宿主机 5432
TIMESCALE_URL=postgresql+asyncpg://postgres:password@localhost:5432/quant_ts

# ===== Redis 配置 =====
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ===== JWT 配置 =====
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== 行情数据 API =====
MARKET_DATA_API_KEY=your-market-data-api-key
MARKET_DATA_API_URL=https://api.example.com/market

# ===== 券商 API =====
BROKER_API_KEY=your-broker-api-key
BROKER_API_SECRET=your-broker-api-secret
BROKER_API_URL=https://api.broker.com/trade

# ===== 交易时段配置 =====
TRADING_START_TIME=09:25
TRADING_END_TIME=15:00
EOD_SCREEN_TIME=15:30

# ===== 风控默认参数 =====
MAX_SINGLE_STOCK_POSITION=0.15
MAX_SECTOR_POSITION=0.30
DEFAULT_STOP_LOSS_RATIO=0.08

# ===== 数据保留配置 =====
KLINE_HISTORY_YEARS=10
AUDIT_LOG_RETENTION_DAYS=365

# ===== 默认管理员 =====
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123456
